# viju-erp-sync — standalone configuration.
# This app reads ONLY this file. It does not inherit the main API's .env, so it
# behaves the same whether it lives inside the Viju repo or in its own.

SYNC_PORT=3100

# --- Database -----------------------------------------------------------
# The SAME database the main Viju API writes to. The main API owns the Prisma
# migrations; this worker only ever reads and upserts. Never run migrations here.
DATABASE_URL=postgresql://user:pass@host:5432/viju

# --- ERP: YVIJUCRM / Digiwin E10 external REST API -----------------------
# Base URL is NOT in the API docs — get the actual endpoint from the ERP team.
ERP_BASE_URL=https://erp.example.com/restful/standard

# Sent as the `digi-key` header on every call.
ERP_API_KEY=replace-me

# Echoed inside the `digi-host` / `digi-service` JSON headers.
ERP_SERVER_IP=127.0.0.1
ERP_PRODUCT=YVIJUCRM
ERP_HOST_VERSION=5.7
ERP_ACCOUNT=CRM

# The ERP is a Digiwin (Chinese) deployment: its digi-host header declares
# timezone +8 while Viju operates in +1. Confirm which timezone DOC_DATE and
# ORDER_DATE are actually returned in before trusting any date.
ERP_TIMEZONE=+8

ERP_TIMEOUT_MS=30000
ERP_MAX_RETRIES=3
ERP_PAGE_SIZE=100

# Verbose request logging: logs each ERP call's method, URL, headers (digi-key
# redacted) and full request body. Handy while bringing up the integration.
# Turn OFF in normal operation — it is noisy and prints request bodies.
ERP_VERBOSE=false

# Master kill switch. When false the worker boots and serves /health but runs
# no sync jobs — useful for deploying ahead of ERP credentials.
SYNC_ENABLED=true
